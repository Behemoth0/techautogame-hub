# TechAutoGame Hub — Environment Variables
# Скопіюй цей файл як .env.local для локальної розробки
# Для GitHub Actions — додай ці значення в Settings → Secrets → Actions

# ===== ОБОВ'ЯЗКОВІ =====

# Google Gemini AI API (безкоштовно: 15 req/хв)
# Отримати: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Unsplash API для зображень (безкоштовно: 50 req/год)
# Отримати: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
UNSPLASH_SECRET_KEY=your_unsplash_secret_key_here

# Amazon Associates Tag (після реєстрації на affiliate-program.amazon.com)
AMAZON_TAG=techautogame-20

# Vercel токен для деплою
# Отримати: https://vercel.com/account/tokens
VERCEL_TOKEN=your_vercel_token_here

# Cron secret для захисту /api/cron/generate endpoint
CRON_SECRET=your_cron_secret_here

# ===== НЕОБОВ'ЯЗКОВІ =====

# Vercel Deploy Hook URL (генерується в Vercel: Settings → Git → Deploy Hooks)
# VERCEL_DEPLOY_HOOK=https://api.vercel.com/v1/integrations/deploy/...

# Telegram бот для нотифікацій (необов'язково)
# Створити бота: @BotFather в Telegram
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id

# Google Analytics (необов'язково)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# PropellerAds Publisher ID (після реєстрації на propellerads.com)
# NEXT_PUBLIC_PROPELLERADS_ZONE=your_zone_id
